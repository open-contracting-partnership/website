<div
    class="block / report-header"
    style="
        --background-colour: {{ block.background_colour }};
        --text-colour: {{ block.text_colour }};
        --header-top: {{ block.header_top }};
        --header-top-mobile: {{ block.header_top_mobile }};
    "
    data-scroll-prompt-parent
>
    <div class="report-header__header">
        <h1 class="report-header__heading">
            <span style="--size-adjustment: {{ block.heading_size }};">{{ block.heading }}</span>

            {% if block.strapline %}
                <span style="--size-adjustment: {{ block.strapline_size }};">{{ block.strapline }}</span>
            {% endif %}
        </h1>

        {% if block.show_arrow_icon %}
            {% include 'components/scroll-prompt.twig' %}
        {% endif %}
    </div>

    <div class="report-header__image">
        {{ imgix({
            src: block.background_image.url,
            height: block.background_image.height,
            width: block.background_image.width,
            transforms: [{
                w: 512
            }, {
                w: 768
            }, {
                w: 1024
            }, {
                w: 1536
            }, {
                w: 3072
            }],
            sizes: '100vw',
            loading: 'eager'
        }) }}
    </div>
</div>
