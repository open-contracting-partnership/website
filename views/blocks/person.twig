{% set options = { 'id': null } | merge(block.options) %}

<div id="{{ options.id }}" class="block" data-block-type="person">
    <div class="block__background" style="background-color: {{ block.background_colour }};"></div>

    <div class="block__container" style="color: {{ block.text_colour }};">
        {% if block.heading %}
            <h2 class="block__heading">{{ block.heading }}</h2>
        {% endif %}

        {% for contact in block.contacts %}
            <div class="block__author">
                <div class="block__author-avatar">
                    {{ imgix({
                        src: contact.avatar.url,
                        params: {
                            fit: 'crop'
                        },
                        aspect_ratio: [1, 1],
                        transforms: [{
                            w: 128
                        }, {
                            w: 256
                        }, {
                            w: 512
                        }],
                        sizes: '(min-width: 780px) 163px, 88px'
                    }) }}
                </div>

                <div class="block__author-details">
                    <h4 class="block__author-heading">{{ contact.title }}</h4>

                    <p>{{ contact.name_bio }}</p>

                    <div class="block__author-social">
                        {% if contact.email_address %}
                            <a href="mailto:{{ contact.email_address }}" class="">
                                <svg data-icon="mail"><use xlink:href="#icon-mail"></use></svg>
                            </a>
                        {% endif %}

                        {% if contact.twitter_url %}
                            <a href="{{ contact.twitter_url }}" class="">
                                <svg data-icon="twitter"><use xlink:href="#social-twitter"></use></svg>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
