{% set options = { 'id': null } | merge(block.options) %}

<div
    id="{{ options.id }}"
    class="block / card-with-icon"
    data-grid-placement="{{ options.grid_placement }}"
    data-icon="{{ block.icon }}"
    style="
        --text-colour: {{ block.text_colour }}; 
        --background-colour: {{ block.background_colour }};
    "
>
    <div class="card-with-icon__inner">
        <div class="card-with-icon__main">
            <h3 class="card-with-icon__heading">{{ block.heading }}</h3>

            {% if block.strapline %}
                <p>{{ block.strapline }}</p>
            {% endif %}
        </div>

        {% if block.link %}
            <div class="card-with-icon__footer">
                <a
                    href="{{ block.link.url }}"
                    target="{{ block.link.target }}"
                    class="card-with-icon__link"
                >
                    <span>{{ block.link.title }}</span>

                    <svg>
                        <use xlink:href="#icon-arrow-circle"></use>
                    </svg>
                </a>
            </div>
        {% endif %}

        <svg class="card-with-icon__icon" fill="{{ block.text_colour }}">
            <use xlink:href="#card-icon-{{ block.icon }}"></use>
        </svg>
    </div>
</div>
