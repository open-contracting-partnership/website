{
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "defaultBranch": "master"
    },
    "files": {
        "includes": ["vite.config.js", "postcss.config.cjs"]
    },
    "formatter": {
        "indentStyle": "space",
        "lineWidth": 119
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteProperties": "preserve",
            "quoteStyle": "single"
        }
    },
    "json": {
        "formatter": {
            "indentWidth": 4
        }
    }
}
